# SheafJournal launcher configuration
# Change SHEAF_LAUNCHER_UUID when launcher/engine protocol changes incompatibly
# Both sides must match or auth will fail

SHEAF_LAUNCHER_UUID=02

# Window settings
SHEAF_LAUNCHER_TITLE=sheafbase
SHEAF_LAUNCHER_WIDTH=1200
SHEAF_LAUNCHER_HEIGHT=800

# Engine settings
SHEAF_LAUNCHER_PORT_RETRIES=3
SHEAF_LAUNCHER_READY_TIMEOUT=15
